    "customColumn1": {
      "alias": "Etat",
      "allowCellWrapping": false,
      "allowSameOptionsInNewRow": true,
      "buttonStyle": "rgb(3, 179, 101)",
      "cellBackground": "{{(() => { const tableData = Table1.processedTableData || []; return tableData.length > 0 ? tableData.map((currentRow, currentIndex) => (\n  (() => {\n\n    // 🟢 Vert : reçu OU validé à la main\n    if (currentRow.validation_manuelle || currentRow.date_reception) {\n      return \"#95e6b3\";\n    }\n\n    // 🟡 Jaune : commandé\n    if (currentRow.date_commande) {\n      return \"#fde68a\";\n    }\n\n    // 🟠 Orange : demande fournisseur\n    if (currentRow.numero_demande) {\n      return \"#fdba74\";\n    }\n\n    // ⚪ Blanc : non traitée\n    return \"white\";\n\n  })()\n)) : \n  (() => {\n\n    // 🟢 Vert : reçu OU validé à la main\n    if (currentRow.validation_manuelle || currentRow.date_reception) {\n      return \"#95e6b3\";\n    }\n\n    // 🟡 Jaune : commandé\n    if (currentRow.date_commande) {\n      return \"#fde68a\";\n    }\n\n    // 🟠 Orange : demande fournisseur\n    if (currentRow.numero_demande) {\n      return \"#fdba74\";\n    }\n\n    // ⚪ Blanc : non traitée\n    return \"white\";\n\n  })()\n })()}}",
      "columnType": "text",
      "computedValue": "{{(() => { const tableData = Table1.processedTableData || []; return tableData.length > 0 ? tableData.map((currentRow, currentIndex) => ( \n  (() => {\n\n    const formatDate = (d) => {\n      if (!d) return null;\n      const dt = new Date(d);\n      const day   = String(dt.getDate()).padStart(2, \"0\");\n      const month = String(dt.getMonth() + 1).padStart(2, \"0\");\n      const year  = dt.getFullYear();\n      return `${day}/${month}/${year}`;\n    };\n\n    // 1️⃣ Priorité absolue : validation manuelle\n    if (currentRow.validation_manuelle) {\n      return \"Validé à la main\";\n    }\n\n    // 2️⃣ Réception\n    if (currentRow.date_reception) {\n      return `Reçu le ${formatDate(currentRow.date_reception)}`;\n    }\n\n    // 3️⃣ Commande\n    if (currentRow.date_commande) {\n      return `Commandé le ${formatDate(currentRow.date_commande)}`;\n    }\n\n    // 4️⃣ Demande fournisseur\n    if (currentRow.numero_demande) {\n      return \"Demande fournisseur effectuée\";\n    }\n\n    // 5️⃣ Par défaut\n    return \"Non traitée par les achats\";\n\n  })()\n)) :  \n  (() => {\n\n    const formatDate = (d) => {\n      if (!d) return null;\n      const dt = new Date(d);\n      const day   = String(dt.getDate()).padStart(2, \"0\");\n      const month = String(dt.getMonth() + 1).padStart(2, \"0\");\n      const year  = dt.getFullYear();\n      return `${day}/${month}/${year}`;\n    };\n\n    // 1️⃣ Priorité absolue : validation manuelle\n    if (currentRow.validation_manuelle) {\n      return \"Validé à la main\";\n    }\n\n    // 2️⃣ Réception\n    if (currentRow.date_reception) {\n      return `Reçu le ${formatDate(currentRow.date_reception)}`;\n    }\n\n    // 3️⃣ Commande\n    if (currentRow.date_commande) {\n      return `Commandé le ${formatDate(currentRow.date_commande)}`;\n    }\n\n    // 4️⃣ Demande fournisseur\n    if (currentRow.numero_demande) {\n      return \"Demande fournisseur effectuée\";\n    }\n\n    // 5️⃣ Par défaut\n    return \"Non traitée par les achats\";\n\n  })()\n })()}}",
